# ==============================================================================
# DocAi Environment Configuration Template
# Rename this file to .env and configure the appropriate values before running.
# ==============================================================================

# ── LLM Providers (Configure at least one) ────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── LLM Selection ─────────────────────────────────────────────────────────────
LLM_PROVIDER=groq                   # Options: groq, openai, anthropic
LLM_MODEL=llama3-8b-8192            # E.g.: gpt-4o, claude-3-5-sonnet, llama3-8b-8192
LLM_TEMPERATURE=0.0

# ── Crawler — Core ────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# Preferred backend: used as the first choice; the router still escalates
# to other backends automatically based on URL type and failure signals.
# Options: firecrawl | crawl4ai | trafilatura | beautifulsoup
CRAWLER_TYPE=trafilatura
MAX_DEPTH=3
CONCURRENT_REQUESTS=5

# ── Crawler — Politeness ──────────────────────────────────────────────────────
# Minimum seconds between consecutive requests to the same domain.
# Respects Crawl-Delay from robots.txt if that value is higher.
CRAWL_DELAY_SECONDS=0.5

# If True, URLs disallowed by robots.txt are skipped.
# If False (default), a warning is logged but crawling proceeds.
# Set to True for stricter compliance; keep False for most doc sites
# which block all bots in robots.txt even though the content is public.
CRAWL_FORCE_ROBOTS=false

# ── Crawler — URL Filtering ───────────────────────────────────────────────────
# Allow PDF files to be crawled (default: false — PDFs are skipped).
CRAWL_ALLOW_PDF=false

# Allowed domains (comma-separated). Empty = same domain only.
# Example: CRAWL_ALLOWED_DOMAINS=docs.python.org,peps.python.org
CRAWL_ALLOWED_DOMAINS=

# Allowed URL prefixes (comma-separated, takes precedence over domains).
# Example: CRAWL_ALLOWED_PREFIXES=https://docs.python.org/3/
CRAWL_ALLOWED_PREFIXES=

# ── Crawler — Content Validation ─────────────────────────────────────────────
# Pages with fewer characters or words are rejected (error pages, nav pages, etc.)
CRAWL_MIN_CONTENT_CHARS=150
CRAWL_MIN_CONTENT_WORDS=30

# ── Crawler — Backend Behaviour ───────────────────────────────────────────────
# Per-request timeout in seconds (applies to all backends).
CRAWL_BACKEND_TIMEOUT_SECONDS=30

# Max retries per backend before escalating to the next backend.
# Keeping this at 2 prevents excessive Firecrawl API charges.
CRAWL_MAX_RETRIES_PER_BACKEND=2

# ── Embeddings & Vector Database ─────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
VECTOR_DB_TYPE=chroma                # Options: chroma, faiss
VECTOR_DB_DIR=./vectordb_storage

# ── Paths ─────────────────────────────────────────────────────────────────────
KNOWLEDGE_BASE_DIR=./knowledge_base
LOG_DIR=./logs
LOG_LEVEL=INFO
