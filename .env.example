# ==============================================================================
# DocAi Environment Configuration Template
# Rename this file to .env and configure the appropriate values before running.
# ==============================================================================

# LLM Providers (Configure at least one)
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM Selection Configuration
LLM_PROVIDER=groq                   # Options: groq, openai, anthropic
LLM_MODEL=llama3-8b-8192            # Example models: gpt-4o, claude-3-5-sonnet, llama3-8b-8192
LLM_TEMPERATURE=0.0

# Crawler Configuration
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
CRAWLER_TYPE=trafilatura             # Options: firecrawl, crawl4ai, trafilatura, beautifulsoup
MAX_DEPTH=3
CONCURRENT_REQUESTS=5

# Embeddings & Vector Database
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
VECTOR_DB_TYPE=chroma                # Options: chroma, faiss
VECTOR_DB_DIR=./vectordb_storage

# Paths
KNOWLEDGE_BASE_DIR=./knowledge_base
LOG_DIR=./logs
LOG_LEVEL=INFO
